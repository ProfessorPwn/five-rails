# Postgres connection (Neon free tier).
# Copy from Neon dashboard → "Connection string" (use the pooled one).
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/dbname?sslmode=require

# Bearer token used to authenticate management endpoints
# (POST /api/landing-pages, GET /api/submissions). Generate with:
#   openssl rand -hex 32
# This MUST match SERVICE_API_TOKEN in the local Five Rails .env
SERVICE_API_TOKEN=replace-with-32-byte-hex-token

# Comma-separated origin allowlist for /api/submit/[slug] CORS.
# Lock to your own Vercel domain so other sites can't fire submissions
# at your form service. The deployed Vercel URL is the only legit caller.
ALLOWED_FORM_ORIGINS=https://your-form-service.vercel.app
